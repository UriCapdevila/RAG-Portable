OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=gemma3:latest
OLLAMA_EMBEDDING_MODEL=nomic-embed-text:latest
APP_HOST=127.0.0.1
APP_PORT=8000
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=180
RAG_TOP_K=4
RAG_VECTOR_TABLE=document_chunks
RAG_RERANKER_ENABLED=false
RAG_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RAG_GROUNDING_THRESHOLD=0.15
RAG_MAX_REACT_STEPS=3

TTS_ENABLED=true
TTS_VOICE=ef_dora
TTS_LANG=es
TTS_SPEED=1.0
TTS_MODEL_QUANTIZATION=int8
CHAT_HISTORY_ENABLED=true
CHAT_HISTORY_TURNS_FOR_DISAMBIG=4

